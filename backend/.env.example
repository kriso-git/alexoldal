# Copy this file to .env and fill in all values before starting the server.

# Server
PORT=3001
NODE_ENV=development

# JWT — generate long random secrets, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM_STRING_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM_STRING_REFRESH
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Superadmin credentials — set on FIRST BOOT to create the superadmin account.
# After the account is created you can remove these from .env (or keep them to reset the password).
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5175

# Database path (relative to backend/)
DB_PATH=./data/f3xykee.db
