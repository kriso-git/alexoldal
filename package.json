{
  "name": "f3xykee-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "node --watch --env-file=backend/.env backend/server.js",
    "dev:all": "concurrently -n frontend,backend -c cyan,magenta \"vite\" \"node --watch --env-file=backend/.env backend/server.js\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node backend/server.js",
    "postinstall": "npm install --prefix backend"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "vite": "^5.4.0"
  }
}
