{
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://alexoldal-production.up.railway.app/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://alexoldal-production.up.railway.app/uploads/:path*" }
  ]
}
